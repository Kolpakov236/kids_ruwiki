# ============================================================================
# YANDEX AI STUDIO (основной провайдер)
# https://studio.yandex.cloud → API-ключи
# ============================================================================
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://llm.api.cloud.yandex.net/v1
LLM_API_KEY=your_yandex_api_key_here

# Модели Yandex AI Studio (выберите одну):
#   yandexgpt-5-pro      — YandexGPT 5 Pro, лучшее качество (рекомендуется)
#   yandexgpt-5-lite     — YandexGPT 5 Lite, быстрее и дешевле
#   yandexgpt            — YandexGPT 4, классика
#   yandexgpt-lite       — YandexGPT 4 Lite
LLM_MODEL=yandexgpt-5-pro

# Folder ID из Yandex Cloud консоли (нужен для некоторых конфигураций)
# YANDEX_FOLDER_ID=b1g...

# ============================================================================
# АЛЬТЕРНАТИВНЫЕ ПРОВАЙДЕРЫ
# ============================================================================

# Google Gemini:
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-flash
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# LLM_API_KEY=your_google_api_key

# OpenAI / OpenRouter / Mistral:
# LLM_PROVIDER=openai_compatible
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your_openai_key

# Локальный Ollama:
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen2.5:7b-instruct
# LLM_BASE_URL=http://localhost:11434
# LLM_API_KEY=

# ============================================================================
# ПАРАМЕТРЫ ГЕНЕРАЦИИ
# ============================================================================
LLM_TIMEOUT_SECONDS=120
LLM_MAX_INPUT_CHARS=5000
LLM_TEMPERATURE=0.35
LLM_NUM_CTX=8192
LLM_NUM_PREDICT=4000
ENABLE_LLM_REPAIR=true

# ============================================================================
# КАЧЕСТВО КЕША
# Только ответы с bleurt_proxy >= порога попадают в векторный кеш.
# Повышайте для строгого отбора, понижайте чтобы кеш наполнялся быстрее.
# ============================================================================
QUALITY_CACHE_THRESHOLD=0.60

# ============================================================================
# RUWIKI API
# ============================================================================
RUWIKI_API_BASE=https://ruwiki.ru/api/rest_v1

# ============================================================================
# ХРАНЕНИЕ ДАННЫХ
# ============================================================================
SQLITE_PATH=./data/app.db
CHROMA_PATH=./data/chroma
ENABLE_VECTOR_CACHE=true

# ============================================================================
# ЭМБЕДДИНГИ
# ============================================================================
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ============================================================================
# АВТОРИЗАЦИЯ
# ============================================================================
# Случайная строка для подписи JWT (обязательно задайте своё значение!)
SECRET_KEY=your_random_secret_key_here
# URL фронтенда (куда редиректить после OAuth)
FRONTEND_URL=http://127.0.0.1:8000

# OAuth ВКонтакте (https://vk.com/dev/first_guide)
# VK_CLIENT_ID=
# VK_CLIENT_SECRET=

# OAuth Яндекс (https://oauth.yandex.ru)
# YANDEX_CLIENT_ID=
# YANDEX_CLIENT_SECRET=

# ============================================================================
# ПРИМЕЧАНИЯ:
# 1. Никогда не коммитьте реальные API-ключи в репозиторий
# 2. Скопируйте этот файл в .env и заполните нужные поля
# ============================================================================
