RUWIKI_API_BASE=https://ru.ruwiki.ru/api/rest_v1

# LLM provider: gemini, ollama or openai_compatible
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
LLM_API_KEY=your_google_ai_studio_api_key
# You can also use GEMINI_API_KEY or GOOGLE_API_KEY instead of LLM_API_KEY.
LLM_TIMEOUT_SECONDS=120
LLM_MAX_INPUT_CHARS=5000
LLM_TEMPERATURE=0.35
LLM_NUM_CTX=8192
LLM_NUM_PREDICT=3000
ENABLE_LLM_REPAIR=true

# Persistence
SQLITE_PATH=./data/app.db
CHROMA_PATH=./data/chroma
ENABLE_VECTOR_CACHE=false

# Embeddings
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

